{
    "embedding_models": {
        "primary": "text-embedding-3-small",
        "alternatives": [
            "text-embedding-3-large",
            "nomic-embed-text"
        ],
        "fallback_to_local": true
    },
    "llm_models": {
        "primary": "gpt-4o-mini",
        "alternatives": [
            "gpt-4o",
            "anthropic/claude-sonnet-4"
        ]
    },
    "api_config": {
        "openrouter_base_url": "https://openrouter.ai/api/v1",
        "timeout": 30,
        "retry_attempts": 3,
        "retry_delay": 1
    },
    "memory_config": {
        "enable_mem0": true,
        "fallback_to_traditional": true,
        "vector_store": {
            "provider": "chroma",
            "path": "/home/ubuntu/agent_outputs/mem0_db"
        }
    },
    "error_handling": {
        "graceful_degradation": true,
        "log_level": "INFO",
        "continue_on_embedding_error": true,
        "continue_on_memory_error": true
    },
    "ui_config": {
        "port": 7860,
        "host": "0.0.0.0",
        "share": true,
        "debug": false
    }
} 