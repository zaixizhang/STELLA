# STELLA Complete Docker Image - Final Version
FROM python:3.12-slim

# Set working directory
WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    wget \
    build-essential \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender-dev \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# Copy core STELLA files
COPY stella_core.py .
COPY start_stella_web.py .
COPY stella_ui_english.py .
COPY memory_manager.py .
COPY Knowledge_base.py .
COPY predefined_tools.py .
COPY requirements.txt .
COPY Stella.png .
COPY small_logo_b64.txt .
COPY stella_base64.tmp .

# Copy documentation files
COPY README.md .
COPY README-Docker.md .
COPY STELLA-Core-Docker-Package.md .
COPY env.example .

# Copy configuration files
COPY docker-compose.yml .
COPY .dockerignore .

# Copy tools directory (correctly positioned)
COPY new_tools/ ./new_tools/

# Copy prompts directory (correctly positioned)
COPY prompts/ ./prompts/

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Install additional critical dependencies
RUN pip install --no-cache-dir \
    torch \
    torchvision \
    torchaudio \
    statsmodels \
    rdkit \
    plotly \
    opencv-python \
    scikit-learn \
    pandas \
    numpy \
    scipy \
    matplotlib \
    seaborn \
    jupyter \
    ipykernel \
    biopython \
    mem0ai \
    gradio \
    smolagents \
    openai \
    beautifulsoup4 \
    googlesearch-python \
    PyPDF2 \
    mcp \
    threadpoolctl

# Create necessary directories
RUN mkdir -p /app/logs /app/cache /app/agent_outputs /app/data

# Set environment variables
ENV PYTHONPATH=/app
ENV STELLA_HOME=/app
ENV CUDA_VISIBLE_DEVICES=""

# Expose port
EXPOSE 7860

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:7860/ || exit 1

# Default startup command
CMD ["python", "start_stella_web.py"]
