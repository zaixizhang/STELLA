# STELLA Core Docker 环境变量配置示例
# 复制此文件为 .env 并填入你的 API 密钥

# =============================================================================
# 必需的 API 密钥
# =============================================================================

# OpenRouter API 密钥 (用于 LLM 模型访问)
# 获取地址: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# SERPAPI 密钥 (用于增强网络搜索)
# 获取地址: https://serpapi.com/
SERPAPI_API_KEY=your_serpapi_key_here

# PaperQA API 密钥 (用于学术文献分析)
# 获取地址: https://paperqa.ai/
PAPERQA_API_KEY=your_paperqa_key_here

# =============================================================================
# 可选配置
# =============================================================================

# STELLA 主目录
STELLA_HOME=/app

# Python 路径
PYTHONPATH=/app

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 最大内存使用 (MB)
MAX_MEMORY=4096

# 最大并发任务数
MAX_CONCURRENT_TASKS=5

# =============================================================================
# 高级配置 (通常不需要修改)
# =============================================================================

# Gradio 服务器配置
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860

# 缓存配置
CACHE_DIR=/app/cache
CACHE_SIZE=1000

# 工具超时时间 (秒)
TOOL_TIMEOUT=300

# 模型配置
DEFAULT_MODEL=claude-sonnet-4
FALLBACK_MODEL=gpt-4o




